            <Assign DisplayName="Assign -&gt; to sum 50 in each row" sap:VirtualizedContainerService.HintSize="416,176.66666666666666" sap2010:WorkflowViewState.IdRef="Assign_1">
              <Assign.To>
                <OutArgument x:TypeArguments="sd:DataTable">[dt_sumColumn]</OutArgument>
              </Assign.To>
              <Assign.Value>
                <InArgument x:TypeArguments="sd:DataTable" xml:space="preserve">[(From row In dt_inptData _
    Let x = New Object() { _
        row("Item").ToString, _
        row("Quantity").ToString, _
        (CInt(row("Price").ToString) + 50).ToString _
    } _
    Select dt_clone.Rows.Add(x) _
).CopyToDataTable()]</InArgument>
              </Assign.Value>
            </Assign>
            <Assign DisplayName="Process updated the specific row" sap:VirtualizedContainerService.HintSize="416,176.66666666666666" sap2010:WorkflowViewState.IdRef="Assign_3">
              <Assign.To>
                <OutArgument x:TypeArguments="sd:DataTable">[st_sumSpecificrow]</OutArgument>
              </Assign.To>
              <Assign.Value>
                <InArgument x:TypeArguments="sd:DataTable" xml:space="preserve">[(From row In dt_inptData _
    Let x = New Object() { _
        row("Item").ToString, _
        row("Quantity").ToString, _
        If(row("Item").ToString.Contains("Orange"), _
           (CInt(row("Price").ToString) + 50).ToString, _
           row("Price").ToString) _
    } _
    Select dt_clone.Rows.Add(x) _
).CopyToDataTable()]</InArgument>
              </Assign.Value>
            </Assign>
            <Assign DisplayName="Process remove extrac space from the row" sap:VirtualizedContainerService.HintSize="416,176.66666666666666" sap2010:WorkflowViewState.IdRef="Assign_4">
              <Assign.To>
                <OutArgument x:TypeArguments="sd:DataTable">[dt_outAfterRemoveExtra]</OutArgument>
              </Assign.To>
              <Assign.Value>
                <InArgument x:TypeArguments="sd:DataTable" xml:space="preserve">[(From row In dt_inptDataFull.AsEnumerable _
 Select dt_inptDataFull.Clone.Rows.Add(New Object() { _
    row("Invoice Number").ToString, _
    row("Vendor Tax ID").ToString, _
    row("Invoice Item").ToString, _
    If(row("Total").ToString.Contains(" "), _
       row("Total").ToString.Split(" "c)(0), _
       row("Total").ToString), _
    row("Date").ToString _
 })).CopyToDataTable()]</InArgument>
              </Assign.Value>
            </Assign>
